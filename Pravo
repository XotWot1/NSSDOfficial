<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Анкета-заявление — НССД</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --navy: #1f3a7a;
    --accent-yellow: #ffb700; 
    --bg: #f3f4f6; 
    --white: #ffffff;
    --text: #1a1a2e; 
    --text-muted: #6b7280;
    --border: #d1d8f0; 
    --card-shadow: 0 4px 16px rgba(23, 37, 84, 0.08);
    --error-color: #dc2626;
  }
  body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; padding: 0 0 60px; }

  /* --- HEDER --- */
  .hero { 
    background: var(--navy); 
    padding: 40px 20px 50px; 
    text-align: center; 
    position: relative; 
    overflow: hidden; 
  }
  
  .hero-stripes {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 45%;
    min-width: 200px;
    max-width: 500px;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }
  .stripe {
    position: absolute;
    height: 200%;
    top: -50%;
    right: -20%;
    transform-origin: top right;
    transform: rotate(-35deg);
  }
  .stripe-white-1 { width: 80%; background: var(--white); right: 0; }
  .stripe-yellow { width: 90%; background: var(--accent-yellow); right: -30%; }
  .stripe-white-2 { width: 70%; background: var(--white); right: -45%; }

  .logo-wrap { 
    position: relative; z-index: 2;
    display: inline-flex; flex-direction: column; align-items: center; gap: 4px;
    background: rgba(255,255,255,0.08); padding: 10px 20px 10px; border-radius: 12px; border:1px solid rgba(255,255,255,0.15);
    margin-bottom: 16px;
  }
  
  .logo-svg { height: 34px; width: auto; display: block; }
  .logo-text { 
    font-family: 'Montserrat', sans-serif; 
    font-weight: 700; 
    font-size: 10px; 
    color: var(--white); 
    letter-spacing: 1.2px; 
    opacity: 0.9;
    white-space: nowrap;
  }

  .hero h1 { 
    font-family:'Montserrat',sans-serif; font-size:clamp(22px,5vw,32px); font-weight:800; 
    color:var(--white); line-height:1.2; margin-bottom:12px; position:relative; z-index:2; 
  }
  .hero-sub { 
    font-size:14px; color:rgba(255,255,255,0.85); max-width:480px; margin:0 auto; 
    line-height:1.6; position:relative; z-index:2; 
  }
  .trust-bar { display:flex; justify-content:center; gap:24px; margin-top:24px; flex-wrap:wrap; position:relative; z-index:2; }
  .trust-item { display:flex; align-items:center; gap:7px; font-size:12px; color:rgba(255,255,255,0.9); font-weight:500; }
  .trust-dot { width:7px; height:7px; border-radius:50%; background:var(--accent-yellow); flex-shrink:0; }

  /* --- Прогресс бар --- */
  .progress-wrap { background:var(--white); padding:16px 20px; border-bottom:1px solid var(--border); position:sticky; top:0; z-index:100; box-shadow:0 2px 12px rgba(0,0,0,0.04); }
  .progress-info { display:flex; justify-content:space-between; align-items:center; max-width:680px; margin:0 auto 8px; font-size:12px; color:var(--text-muted); }
  .progress-label { font-weight:600; color:var(--navy); }
  .progress-bar-bg { max-width:680px; margin:0 auto; height:5px; background:var(--border); border-radius:10px; overflow:hidden; }
  .progress-bar-fill { height:100%; background:var(--navy); border-radius:10px; transition:width 0.4s ease; width:0%; }

  .container { max-width:680px; margin:0 auto; padding:0 16px; position: relative; z-index: 2; }
  
  /* --- Секции формы --- */
  .section { margin-top:32px; }
  .section-header { display:flex; align-items:center; gap:12px; margin-bottom:16px; position:relative; }
  
  .section-header::before {
    content: '';
    position: absolute;
    top: -6px;
    left: 0;
    width: 40px;
    height: 4px;
    background: var(--accent-yellow);
    border-radius: 4px;
  }

  .section-icon { width:36px; height:36px; border-radius:10px; background:var(--navy); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .section-icon svg { width:18px; height:18px; fill:none; stroke:white; stroke-width:2; stroke-linecap:round; stroke-linejoin:round; }
  .section-title { font-family:'Montserrat',sans-serif; font-size:16px; font-weight:700; color:var(--navy); letter-spacing:0.3px; margin-top: 4px;}
  .card { background:var(--white); border-radius:16px; padding:24px; box-shadow:var(--card-shadow); border:1px solid rgba(209,216,240,0.5); display:flex; flex-direction:column; gap:18px; }
  .field { display:flex; flex-direction:column; gap:6px; }
  .field-label { font-size:13px; font-weight:600; color:var(--navy); display:flex; align-items:center; gap:4px; }
  .req { color:var(--error-color); font-size:14px; }
  
  /* Поля ввода с валидацией */
  .field-input { 
    border:1.5px solid var(--border); border-radius:10px; padding:11px 14px; font-size:14px; font-family:'Inter',sans-serif; color:var(--text); background:var(--white); transition:border-color 0.2s,box-shadow 0.2s; outline:none; width:100%; 
  }
  .field-input:focus { border-color:var(--navy); box-shadow:0 0 0 3px rgba(23,37,84,0.08); }
  .field-input:invalid:not(:placeholder-shown) { border-color: var(--error-color); }
  
  .field-error { font-size:11px; color:var(--error-color); display:none; margin-top: 3px;}
  .field-input:invalid:not(:placeholder-shown) ~ .field-error { display:block; }
  
  /* Кастомные чекбоксы / радио */
  .radio-group, .checkbox-group { display:flex; flex-direction:column; gap:8px; }
  .radio-label, .checkbox-label { display:flex; align-items:center; gap:10px; padding:10px 14px; border:1.5px solid var(--border); border-radius:10px; cursor:pointer; transition:all 0.2s; font-size:14px; color:var(--text); user-select:none; }
  .radio-label:hover, .checkbox-label:hover { border-color:var(--navy); background:rgba(23,37,84,0.02); }
  .radio-label input, .checkbox-label input { display:none; }
  .radio-label.selected, .checkbox-label.selected { border-color:var(--navy); background:rgba(23,37,84,0.04); color:var(--navy); font-weight:500; }
  .radio-custom, .checkbox-custom { width:18px; height:18px; border:2px solid var(--border); flex-shrink:0; transition:all 0.2s; display:flex; align-items:center; justify-content:center; }
  .radio-custom { border-radius:50%; }
  .checkbox-custom { border-radius:5px; }
  .radio-label.selected .radio-custom { border-color:var(--navy); background:var(--navy); box-shadow:inset 0 0 0 3px white; }
  .checkbox-label.selected .checkbox-custom { border-color:var(--navy); background:var(--navy); }
  .checkbox-label.selected .checkbox-custom::after { content:''; display:block; width:9px; height:5px; border-left:2px solid white; border-bottom:2px solid white; transform:rotate(-45deg) translateY(-1px); }
  .field-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
  @media (max-width:480px) { .field-row { grid-template-columns:1fr; } }

  /* Отзывы */
  .reviews-block { margin-top:32px; }
  .reviews-header { display:flex; align-items:center; gap:10px; margin-bottom:6px; flex-wrap:wrap; }
  .ya-badge { background:#FC3F1D; color:white; font-size:11px; font-weight:700; padding:3px 10px; border-radius:20px; letter-spacing:0.5px; }
  .reviews-meta { font-size:13px; color:var(--text-muted); display:flex; align-items:center; gap:8px; }
  .stars { color:#f59e0b; font-size:13px; letter-spacing:1px; }
  .reviews-sub { font-size:12px; color:var(--text-muted); margin-bottom:12px; }
  .reviews-scroll { display:flex; gap:14px; overflow-x:auto; padding-bottom:10px; scroll-snap-type:x mandatory; -webkit-overflow-scrolling:touch; }
  .reviews-scroll::-webkit-scrollbar { height:4px; }
  .reviews-scroll::-webkit-scrollbar-track { background:var(--border); border-radius:10px; }
  .reviews-scroll::-webkit-scrollbar-thumb { background:var(--navy); border-radius:10px; }
  .review-card { background:var(--white); border-radius:14px; padding:16px; min-width:270px; max-width:290px; flex-shrink:0; scroll-snap-align:start; box-shadow:var(--card-shadow); border:1px solid rgba(209,216,240,0.5); position:relative; }
  .review-top { display:flex; align-items:center; gap:10px; margin-bottom:6px; }
  .review-avatar { width:36px; height:36px; border-radius:50%; background:var(--navy); display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:700; color:white; flex-shrink:0; }
  .review-name { font-size:13px; font-weight:600; color:var(--navy); line-height:1.3; }
  .review-date { font-size:11px; color:var(--text-muted); margin-top:1px; }
  .review-stars { color:#f59e0b; font-size:11px; letter-spacing:1px; margin-bottom:4px; }
  .review-text { font-size:13px; color:var(--text); line-height:1.6; }
  .review-result { display:inline-block; margin-top:8px; background:#E1F5EE; color:#085041; font-size:11px; font-weight:600; padding:3px 10px; border-radius:20px; }

  /* Кнопка отправки */
  .submit-wrap { margin-top:32px; padding:24px; background:var(--white); border-radius:16px; box-shadow:var(--card-shadow); border:1px solid rgba(209,216,240,0.5); text-align:center; }
  .submit-note { font-size:12px; color:var(--text-muted); margin-bottom:18px; line-height:1.6; display:flex; align-items:flex-start; gap:8px; text-align:left; }
  .submit-note svg { width:16px; height:16px; flex-shrink:0; margin-top:1px; fill:var(--text-muted); }
  
  .btn-submit { 
    width:100%; padding:16px; background:var(--accent-yellow); color:var(--navy); border:none; 
    border-radius:12px; font-family:'Montserrat',sans-serif; font-size:15px; font-weight:700; letter-spacing:0.5px; 
    cursor:pointer; transition:all 0.25s; 
  }
  .btn-submit:hover { transform:translateY(-1px); box-shadow:0 6px 20px rgba(251, 191, 36, 0.4); }
  .btn-submit:active { transform:translateY(0); }
  .btn-submit:disabled { opacity:0.6; cursor:not-allowed; transform:none; }
  .btn-inner { display:flex; align-items:center; justify-content:center; gap:10px; }
  .btn-arrow { transition:transform 0.25s; }
  .btn-submit:hover .btn-arrow { transform:translateX(4px); }
  .spinner { width:20px; height:20px; border:2px solid rgba(23,37,84,0.2); border-top-color:var(--navy); border-radius:50%; animation:spin 0.7s linear infinite; display:none; }
  @keyframes spin { to { transform:rotate(360deg); } }
  
  .success-screen { display:none; text-align:center; padding:60px 20px; }
  .success-icon { width:72px; height:72px; border-radius:50%; background:var(--navy); display:flex; align-items:center; justify-content:center; margin:0 auto 20px; animation:pop 0.4s ease; }
  @keyframes pop { 0%{transform:scale(0.5);opacity:0;} 80%{transform:scale(1.1);} 100%{transform:scale(1);opacity:1;} }
  .success-title { font-family:'Montserrat',sans-serif; font-size:22px; font-weight:700; color:var(--navy); margin-bottom:10px; }
  .success-text { font-size:14px; color:var(--text-muted); line-height:1.7; max-width:360px; margin:0 auto; }
</style>
</head>
<body>

<div class="hero">
  <div class="hero-stripes">
    <div class="stripe stripe-white-1"></div>
    <div class="stripe stripe-yellow"></div>
    <div class="stripe stripe-white-2"></div>
  </div>

  <div class="logo-wrap">
    <svg class="logo-svg" viewBox="0 0 120 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <g clip-path="url(#clip0_833_6145)">
        <mask id="mask0_833_6145" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="0" y="0" width="120" height="24">
