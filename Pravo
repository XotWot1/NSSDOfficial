    <span class="logo-text">НАЦИОНАЛЬНАЯ СЛУЖБА СПИСАНИЯ ДОЛГОВ</span>
  </div>
  
  <h1>Анкета-заявление клиента</h1>
  <p class="hero-sub">Процедура списания / реструктуризации задолженности. Заполните анкету — мы свяжемся с вами и расскажем о дальнейших шагах.</p>
  <div class="trust-bar">
    <div class="trust-item"><div class="trust-dot"></div>Более 16 000 завершённых дел</div>
    <div class="trust-item"><div class="trust-dot"></div>Полностью под ключ</div>
    <div class="trust-item"><div class="trust-dot"></div>Рейтинг 4,8 на Яндексе</div>
  </div>
</div>

<div class="progress-wrap">
  <div class="progress-info">
    <span class="progress-label" id="progress-label">Начало заполнения</span>
    <span id="progress-pct">0%</span>
  </div>
  <div class="progress-bar-bg"><div class="progress-bar-fill" id="progress-fill"></div></div>
</div>

<div class="container" id="form-container">
<form id="mainForm" novalidate>
  <div class="section">
    <div class="section-header">
      <div class="section-title">Личные данные</div>
    </div>
    <div class="card">
      <div class="field">
        <label class="field-label">ФИО <span class="req">*</span></label>
        <input type="text" class="field-input" name="fio" placeholder="Иванов Иван Иванович" required>
        <span class="field-error">Пожалуйста, укажите ФИО</span>
      </div>
      <div class="field-row">
        <div class="field">
          <label class="field-label">Дата рождения <span class="req">*</span></label>
          <input type="date" class="field-input" name="dob" required>
          <span class="field-error">Пожалуйста, укажите дату рождения</span>
        </div>
        <div class="field">
          <label class="field-label">Место рождения <span class="req">*</span></label>
          <input type="text" class="field-input" name="pob" placeholder="Город / Область" required>
          <span class="field-error">Укажите место рождения</span>
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label class="field-label">Серия и номер паспорта <span class="req">*</span></label>
          <input type="text" class="field-input" name="passport_num" placeholder="0000 000000" pattern="[0-9]{4} [0-9]{6}" required>
          <span class="field-error">Формат: 4 цифры, пробел, 6 цифр</span>
        </div>
        <div class="field">
          <label class="field-label">Дата выдачи <span class="req">*</span></label>
          <input type="date" class="field-input" name="passport_date" required>
          <span class="field-error">Укажите дату выдачи</span>
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label class="field-label">Код подразделения <span class="req">*</span></label>
          <input type="text" class="field-input" name="passport_code" placeholder="000-000" pattern="[0-9]{3}-[0-9]{3}" required>
          <span class="field-error">Формат: 3 цифры, тире, 3 цифры</span>
        </div>
        <div class="field">
          <label class="field-label">Номер телефона <span class="req">*</span></label>
          <input type="tel" class="field-input" name="phone" id="phoneInput" placeholder="+7 (___) ___-__-__" required>
          <span class="field-error">Укажите номер телефона</span>
        </div>
      </div>
      <div class="field">
        <label class="field-label">Адрес регистрации <span class="req">*</span></label>
        <input type="text" class="field-input" name="address" placeholder="Город, улица, дом, квартира" required>
        <span class="field-error">Укажите адрес регистрации</span>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-header">
      <div class="section-title">Вид процедуры и занятость</div>
    </div>
    <div class="card">
      <div class="field">
        <label class="field-label">Вид процедуры <span class="req">*</span></label>
        <div class="radio-group" data-name="procedure">
          <label class="radio-label"><input type="radio" name="procedure" value="Списание задолженности" required><div class="radio-custom"></div>Списание задолженности</label>
          <label class="radio-label"><input type="radio" name="procedure" value="Реструктуризация задолженности"><div class="radio-custom"></div>Реструктуризация задолженности</label>
          <label class="radio-label"><input type="radio" name="procedure" value="Мировое соглашение + списание"><div class="radio-custom"></div>Мировое соглашение + списание</label>
          <label class="radio-label"><input type="radio" name="procedure" value="Мировое соглашение + реструктуризация"><div class="radio-custom"></div>Мировое соглашение + реструктуризация</label>
        </div>
      </div>
      <div class="field">
        <label class="field-label">Работаете официально? <span class="req">*</span></label>
        <div class="radio-group" data-name="employed">
          <label class="radio-label"><input type="radio" name="employed" value="Да" required><div class="radio-custom"></div>Да</label>
          <label class="radio-label"><input type="radio" name="employed" value="Нет"><div class="radio-custom"></div>Нет</label>
        </div>
      </div>
      <div class="field">
        <label class="field-label">Сумма дохода (в месяц) <span class="req">*</span></label>
        <input type="number" class="field-input" name="income" placeholder="Например: 45000" required>
        <span class="field-error">Укажите суммарный доход</span>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-header">
      <div class="section-title">Долговая нагрузка</div>
    </div>
    <div class="card">
      <div class="field-row">
        <div class="field">
          <label class="field-label">Сумма долга <span class="req">*</span></label>
          <input type="number" class="field-input" name="debt_amount" placeholder="Например: 2000000" required>
          <span class="field-error">Укажите сумму долга</span>
        </div>
        <div class="field">
          <label class="field-label">Ежемесячный платёж <span class="req">*</span></label>
          <input type="number" class="field-input" name="monthly_payment" placeholder="Общий по всем кредитам" required>
