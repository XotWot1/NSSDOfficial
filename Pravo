<div class="container">
  <div class="success-screen" id="successScreen">
    <div class="success-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div>
    <div class="success-title">Заявка отправлена!</div>
    <p class="success-text">Ваша анкета получена. Специалист НССД свяжется с вами в ближайшее время для уточнения деталей и следующих шагов.</p>
  </div>
</div>

<script>
  // НОВАЯ ССЫЛКА НА ВАШУ ТАБЛИЦУ (оригинальная, рабочая)
  const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbzLQWD1NTQdI_XdE-nu1CTIphVC17tL1KK-pGYmdIt6fO52VV-OV8UVCtD2OSimLI0UwQ/exec';

  // --- МАСКА ТЕЛЕФОНА ---
  const phoneInput = document.getElementById('phoneInput');
  phoneInput.addEventListener('input', function(e) {
    let value = this.value.replace(/\D/g, '');
    if (!value.startsWith('7') && value.length > 0) {
        value = '7' + value;
    }
    let formatted = '';
    if (value.length > 0) {
        formatted = '+7 ';
        if (value.length > 1) {
            formatted += '(' + value.substring(1, 4);
        }
        if (value.length >= 4) {
            formatted += ') ' + value.substring(4, 7);
        }
        if (value.length >= 7) {
            formatted += '-' + value.substring(7, 9);
        }
        if (value.length >= 9) {
            formatted += '-' + value.substring(9, 11);
        }
    }
    this.value = formatted;
  });

  // --- КАСТОМНЫЕ РАДИО И ЧЕКБОКСЫ ---
  document.querySelectorAll('.radio-group').forEach(group => {
    group.querySelectorAll('.radio-label').forEach(label => {
      label.addEventListener('click', (e) => {
        e.preventDefault();
        group.querySelectorAll('.radio-label').forEach(l => l.classList.remove('selected'));
        label.classList.add('selected');
        label.querySelector('input').checked = true;
        updateProgress();
      });
    });
  });

  document.querySelectorAll('.checkbox-group').forEach(group => {
    group.querySelectorAll('.checkbox-label').forEach(label => {
      label.addEventListener('click', (e) => {
        e.preventDefault();
        label.classList.toggle('selected');
        label.querySelector('input').checked = label.classList.contains('selected');
        updateProgress();
      });
    });
  });

  // --- ПРОГРЕСС-БАР ---
  const fields = ['fio','dob','phone','address','debt_amount','income'];
  const radioGroups = ['procedure','employed','overdue','arrests','family','transactions','ip'];

  function updateProgress() {
    let filled = 0, total = fields.length + radioGroups.length;
    fields.forEach(n => { if(document.querySelector(`[name="${n}"]`)?.value.trim()) filled++; });
    radioGroups.forEach(n => { if(document.querySelector(`[name="${n}"]:checked`)) filled++; });
    const pct = Math.round((filled / total) * 100);
    document.getElementById('progress-fill').style.width = pct + '%';
    document.getElementById('progress-pct').textContent = pct + '%';
    const labels = ['Начало заполнения','Заполняем данные','Почти готово','Финальный шаг'];
    document.getElementById('progress-label').textContent = labels[Math.min(3, Math.floor(pct/25))];
  }

  document.querySelectorAll('.field-input').forEach(i => i.addEventListener('input', updateProgress));

  // --- СБОР ДАННЫХ И ОТПРАВКА (ЧЕРЕЗ FormData) ---
  function collectData() {
    const f = document.getElementById('mainForm');
    const get = n => f.querySelector(`[name="${n}"]`)?.value || '';
    const getRadio = n => f.querySelector(`[name="${n}"]:checked`)?.value || '';
    const getChecks = n => [...f.querySelectorAll(`[data-name="${n}"] input:checked`)].map(i=>i.value).join(', ');
    
    const data = {
      'Дата и время': new Date().toLocaleString('ru-RU'),
      'ФИО': get('fio'), 'Дата рождения': get('dob'), 'Место рождения': get('pob'),
      'Серия и номер паспорта': get('passport_num'), 'Дата выдачи паспорта': get('passport_date'),
      'Код подразделения': get('passport_code'), 'Телефон': get('phone'),
      'Адрес регистрации': get('address'), 'Вид процедуры': getRadio('procedure'),
      'Работает официально': getRadio('employed'), 'Сумма дохода (в месяц)': get('income'),
      'Сумма долга': get('debt_amount'), 'Ежемесячный платёж': get('monthly_payment'),
      'Просрочки': getRadio('overdue'), 'Кредиторы': getChecks('creditors'),
      'Аресты / исполнительные производства': getRadio('arrests'),
      'Семейное положение': getRadio('family'), 'Дети': getChecks('children'),
      'Имущество': getChecks('property'), 'Сделки с имуществом за 3 года': getRadio('transactions'),
      'Действующее ИП': getRadio('ip'),
    };

    const formData = new FormData();
    formData.append('data', JSON.stringify(data));
    return formData;
  }

  document.getElementById('mainForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const btn = document.getElementById('submitBtn');
    const spinner = document.getElementById('spinner');
    const btnText = document.getElementById('btnText');
    const btnArrow = document.getElementById('btnArrow');
    
    btn.disabled = true; 
    spinner.style.display = 'block';
    btnText.textContent = 'Отправляем...'; 
    btnArrow.style.display = 'none';
    
    try {
      const payload = collectData(); 
      await fetch(SCRIPT_URL, { 
          method:'POST', 
          mode:'no-cors', 
          body: payload 
      });
      document.getElementById('form-container').style.display = 'none';
      document.getElementById('successScreen').style.display = 'block';
      document.getElementById('successScreen').scrollIntoView({ behavior:'smooth' });
    } catch(err) {
      btn.disabled = false; 
      spinner.style.display = 'none';
      btnText.textContent = 'Отправить заявку'; 
      btnArrow.style.display = 'block';
      alert('Ошибка отправки. Проверьте соединение и попробуйте снова.');
    }
  });
</script>
